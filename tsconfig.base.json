{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@safetyos/ui": ["./packages/ui/src"],
      "@safetyos/ui/*": ["./packages/ui/src/*"],
      "@safetyos/design-tokens": ["./packages/design-tokens/src"],
      "@safetyos/design-tokens/*": ["./packages/design-tokens/src/*"],
      "@safetyos/icons": ["./packages/icons/src"],
      "@safetyos/icons/*": ["./packages/icons/src/*"],
      "@safetyos/shared-types": ["./packages/shared-types/src"],
      "@safetyos/shared-types/*": ["./packages/shared-types/src/*"],
      "@safetyos/api-client": ["./packages/api-client/src"],
      "@safetyos/api-client/*": ["./packages/api-client/src/*"],
      "@safetyos/validation": ["./packages/validation/src"],
      "@safetyos/validation/*": ["./packages/validation/src/*"],
      "@safetyos/hooks": ["./packages/hooks/src"],
      "@safetyos/hooks/*": ["./packages/hooks/src/*"],
      "@safetyos/utils": ["./packages/utils/src"],
      "@safetyos/utils/*": ["./packages/utils/src/*"],
      "@safetyos/config": ["./packages/config/src"],
      "@safetyos/config/*": ["./packages/config/src/*"],
      "@safetyos/analytics": ["./packages/analytics/src"],
      "@safetyos/analytics/*": ["./packages/analytics/src/*"],
      "@safetyos/i18n": ["./packages/i18n/src"],
      "@safetyos/i18n/*": ["./packages/i18n/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}
