# SafetyOS Environment Variables Template

# Monorepo Environment
NODE_ENV=development
LOG_LEVEL=debug

# Application Endpoints
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_COPILOT_URL=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080/ws

# Database Connection Strings
DATABASE_URL=postgresql://safetyos:safetyos_dev_password@localhost:5432/safetyos
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=safetyos_dev_password
QDRANT_URL=http://localhost:6333
KAFKA_BROKERS=localhost:9092

# Auth & OIDC
JWT_SECRET=dev_super_secret_jwt_key_safetyos_2026_change_in_prod
OIDC_ISSUER=http://localhost:8080/auth/realms/safetyos
OIDC_CLIENT_ID=safetyos-web
OIDC_CLIENT_SECRET=dev_oidc_client_secret

# AI & LLM Services
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
VECTOR_EMBEDDING_MODEL=text-embedding-3-large
# Kafka topic for alerts
KAFKA_TOPIC_ALERTS=alerts

# CV service URL (default points to Docker network service)
CV_SERVICE_URL=http://cv_service:8002
